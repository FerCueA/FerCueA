---
import { navigationLinks } from '../../data/portfolio';

const brandName = 'AleixoFdezCuevas';
---

<header class="sticky top-0 z-20 border-b border-ink/8 bg-paper/85 backdrop-blur-xl">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 lg:px-8">
		<a href="#inicio" class="font-serif text-xl font-bold tracking-wide text-violet-deep sm:text-2xl">{brandName}</a>
		<nav class="hidden gap-6 text-sm text-ink/72 md:flex">
			{navigationLinks.map((link) => (
				<a href={link.href} class="transition hover:text-gold-main">{link.label}</a>
			))}
		</nav>
	</div>
</header>