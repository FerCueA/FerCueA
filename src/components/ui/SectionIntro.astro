---
interface Props {
	kicker: string;
	title: string;
	description?: string;
	align?: 'left' | 'between';
}

const { kicker, title, description, align = 'left' } = Astro.props;
---

<div class:list={[
	'mb-6 gap-5 sm:mb-8 sm:gap-6',
	align === 'between' ? 'flex flex-col items-start justify-between lg:flex-row lg:items-end' : '',
]}>
	<div>
		<p class="text-[0.7rem] uppercase tracking-[0.2em] text-gold-soft sm:text-sm sm:tracking-[0.26em]">{kicker}</p>
		<h2 class="mt-2 font-serif text-3xl leading-tight text-ink sm:text-4xl">{title}</h2>
	</div>
	{description && <p class="max-w-2xl text-sm leading-6 text-ink/62 sm:leading-7">{description}</p>}
</div>