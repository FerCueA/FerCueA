---
import { skillGroups } from '../../data/portfolio';
import SectionIntro from '../ui/SectionIntro.astro';

const iconPaths = {
	code: 'M8 8l-4 4 4 4M16 8l4 4-4 4M13 5l-2 14',
	cloud: 'M7 18h9a4 4 0 0 0 .4-8A5.5 5.5 0 0 0 6 9.5 4.5 4.5 0 0 0 7 18Z',
	database: 'M12 4c-4.4 0-8 1.3-8 3v10c0 1.7 3.6 3 8 3s8-1.3 8-3V7c0-1.7-3.6-3-8-3Zm0 0c4.4 0 8 1.3 8 3s-3.6 3-8 3-8-1.3-8-3 3.6-3 8-3Zm-8 8c0 1.7 3.6 3 8 3s8-1.3 8-3M4 17c0 1.7 3.6 3 8 3s8-1.3 8-3',
	tool: 'm14.7 6.3 3 3M5 19l3.5-1 9.2-9.2a2.1 2.1 0 0 0-3-3L5.5 15 5 19Z',
} as const;
---

<section id="tecnologias" class="py-12 lg:py-16">
	<div class="rounded-4xl border border-ink/8 bg-surface/88 p-8 shadow-sm shadow-black/5 backdrop-blur-xl">
		<SectionIntro
			kicker="Tecnologias"
			title="Stack, plataformas y herramientas"
			description="Este bloque resume la base tecnica y las herramientas con las que desarrollo, despliego y mantengo proyectos web con criterio profesional." 
		/>
		<div class="grid gap-5 lg:grid-cols-2">
			{skillGroups.map((group) => (
				<div class="rounded-3xl border border-ink/8 bg-paper/85 p-6">
					<div class="flex items-center gap-4">
						<div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-gold-main/20 bg-gold-main/10 text-gold-soft">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="h-6 w-6">
								<path d={iconPaths[group.icon]} stroke-linecap="round" stroke-linejoin="round"></path>
							</svg>
						</div>
						<div>
							<p class="text-sm uppercase tracking-[0.22em] text-gold-soft">{group.title}</p>
							<p class="mt-1 text-sm leading-6 text-ink/60">{group.description}</p>
						</div>
					</div>
					<div class="mt-4 flex flex-wrap gap-3">
						{group.items.map((item) => (
							<span class="rounded-full border border-violet-main/14 bg-violet-soft/40 px-4 py-2 text-sm font-medium text-violet-deep">
								{item}
							</span>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</section>